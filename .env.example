# OpsEcho Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://opscho:opscho_password@postgres:5432/opscho

# Ollama (Local LLM)
OLLAMA_URL=http://ollama:11434

# GitHub (optional - for Git webhook collector)
GITHUB_TOKEN=

# AWS (optional - for EC2 collector)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Kubernetes (optional - uses kubeconfig if available)
KUBECONFIG=
